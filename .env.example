# Matometa Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent backend: "ollama", "cli" or "sdk"
AGENT_BACKEND=ollama

# LLM backend for short prompts (titles, tags). Defaults to AGENT_BACKEND.
# LLM_BACKEND=ollama

# Claude CLI path (uses system default if not set)
# CLAUDE_CLI=claude

# Claude model override
# CLAUDE_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Ollama (self-hosted LLM)
# =============================================================================

# Ollama endpoint reachable from Matometa
OLLAMA_BASE_URL=http://ollama:11434

# Default model for chat
OLLAMA_MODEL=qwen3-coder-next

# Optional per-task models
# OLLAMA_TITLE_MODEL=qwen3-coder-next
# OLLAMA_TAG_MODEL=qwen3-coder-next

# Optional tuning
# OLLAMA_REQUEST_TIMEOUT=120
# OLLAMA_STREAM=true
# OLLAMA_STREAM_CHUNK_SIZE=200
# OLLAMA_MAX_HISTORY_CHARS=50000
# OLLAMA_TOOL_MAX_STEPS=6
# OLLAMA_TEMPERATURE=0.2
# OLLAMA_NUM_CTX=0

# =============================================================================
# Web Server
# =============================================================================

# Server binding
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_DEBUG=true

# Public URL for shareable links (set per deployment)
# PUBLIC_URL=http://127.0.0.1:5000

# Default user for local development (when oauth-proxy not present)
DEFAULT_USER=admin@localhost

# Admin users who can see all conversations (comma-separated emails)
ADMIN_USERS=admin@localhost

# =============================================================================
# Data Directory
# =============================================================================

# Override data directory (SQLite database, interactive files)
# Useful for local development with production data
# DATA_DIR=./data-remote

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection URL (Scalingo provides this automatically)
# If not set, SQLite is used for local development
# DATABASE_URL=postgres://user:password@host:port/dbname

# =============================================================================
# S3-Compatible Object Storage (optional)
# =============================================================================

# S3 storage for interactive files (dashboards, exports)
# If not configured, files are stored locally in data/interactive/
# Works with AWS S3, Scaleway Object Storage, MinIO, etc.

# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=fr-par
# S3_PREFIX=interactive/

# =============================================================================
# Local Docker Development (docker-compose.local.yml)
# =============================================================================

# PostgreSQL credentials for local docker
POSTGRES_USER=matometa
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=matometa

# MinIO (local S3) credentials for local docker
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-local-dev
