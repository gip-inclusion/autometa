# Matometa Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Core — Agent
# =============================================================================

# Agent backend: "cli" (Claude Code CLI) or "cli-ollama" (Ollama via CLI)
AGENT_BACKEND=cli

# LLM backend for short prompts (titles, tags). Defaults to AGENT_BACKEND.
# LLM_BACKEND=cli

# =============================================================================
# Core — Web
# =============================================================================

# Admin users who can see all conversations (comma-separated emails)
ADMIN_USERS=admin@localhost

# Default user for local dev (when no auth proxy)
DEFAULT_USER=admin@localhost

# Server binding (local dev only — Scalingo uses $PORT)
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_DEBUG=true

# Base URL for absolute links shared outside the app
# BASE_URL=https://matometa.ljt.cc/

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection URL. If unset, SQLite is used (local dev).
# Scalingo provides this automatically via the PostgreSQL addon.
# DATABASE_URL=postgres://user:password@host:port/dbname

# Override data directory (SQLite DB, interactive files, uploads)
# DATA_DIR=./data-remote

# =============================================================================
# S3-Compatible Object Storage (optional)
# =============================================================================
# For interactive files (dashboards, exports). If unset, files stay local.
# Works with AWS S3, Scaleway Object Storage, MinIO, etc.

# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=fr-par
# S3_PREFIX=interactive/

# =============================================================================
# Data Sources (configured in config/sources.yaml)
# =============================================================================
# Keys referenced by config/sources.yaml. Only needed for the sources you use.

# Matomo analytics
# MATOMO_API_KEY=your-matomo-token
# MATOMO_URL=https://matomo.inclusion.beta.gov.fr   # only if overriding sources.yaml

# Metabase instances (one key per instance)
# METABASE_STATS_API_KEY=your-stats-api-key
# METABASE_DATALAKE_API_KEY=your-datalake-api-key
# METABASE_DORA_API_KEY=your-dora-api-key
# METABASE_RDVI_API_KEY=your-rdvi-api-key

# Notion (research corpus sync)
# NOTION_TOKEN=secret_...
# NOTION_WISHLIST_DB=notion-database-id

# Grist (webinaire data)
# GRIST_API_KEY=your-grist-api-key

# Slack bot (weekly feedback DMs)
# SLACK_BOT_TOKEN=xoxb-...

# Livestorm
# LIVESTORM_API_KEY=your-livestorm-api-key

# =============================================================================
# Claude Code CLI (when AGENT_BACKEND=cli)
# =============================================================================

# Path to Claude CLI binary (default: "claude" from $PATH)
# CLAUDE_CLI=claude

# Claude model override
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OAuth token for Claude CLI auth (required — bypasses interactive setup wizard)
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# Disable Claude Code auto-memory (recommended in production)
# CLAUDE_CODE_DISABLE_AUTO_MEMORY=1

# =============================================================================
# Scalingo / Container Deployment
# =============================================================================
# These are only relevant when deploying to Scalingo or similar PaaS.

# Set to "1" to skip Claude CLI permission prompts (container is the boundary)
# CONTAINER_ENV=1

# =============================================================================
# OAuth2-Proxy (optional — Google auth on Scalingo)
# =============================================================================
# Only needed when using the betagouv/oauth2-proxy-buildpack.
# The proxy sits in front of the app and injects X-Forwarded-Email.

# OAUTH2_PROXY_PROVIDER=google
# OAUTH2_PROXY_CLIENT_ID=your-google-client-id
# OAUTH2_PROXY_CLIENT_SECRET=your-google-client-secret
# OAUTH2_PROXY_COOKIE_SECRET=random-32-byte-base64
# OAUTH2_PROXY_COOKIE_SECURE=true
# OAUTH2_PROXY_EMAIL_DOMAINS=inclusion.gouv.fr
# OAUTH2_PROXY_REDIRECT_URL=https://your-app.osc-fr1.scalingo.io/oauth2/callback
# OAUTH2_PROXY_SET_XAUTHREQUEST=true
# OAUTH2_PROXY_UPSTREAMS=http://127.0.0.1:8080

# =============================================================================
# Ollama (when AGENT_BACKEND=cli-ollama)
# =============================================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder-next
# OLLAMA_TITLE_MODEL=qwen3-coder-next
# OLLAMA_TAG_MODEL=qwen3-coder-next

# =============================================================================
# Local Docker Development (docker-compose.local.yml)
# =============================================================================

POSTGRES_USER=matometa
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=matometa

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-local-dev

# Activate Ollama container: COMPOSE_PROFILES=ollama
